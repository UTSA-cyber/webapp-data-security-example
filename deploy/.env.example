# =========================================================================
# deploy/.env.example
#
# Copy to deploy/.env before `docker compose up`. Every value below is a
# placeholder — DO NOT use these in production. For local development the
# defaults are fine; for any shared deployment, regenerate every secret.
# =========================================================================

# ----- Postgres (Supabase) ------------------------------------------------
POSTGRES_PASSWORD=postgres-change-me
POSTGRES_DB=postgres

# ----- GoTrue / PostgREST -------------------------------------------------
# JWT_SECRET signs every Supabase JWT. ANON_KEY and SERVICE_ROLE_KEY must be
# JWTs signed with this secret (role=anon and role=service_role respectively).
# For local dev, regenerate via:
#   docker run --rm supabase/auth gotrue-cli generate-jwt --secret $JWT_SECRET --role anon
# Or use Supabase's documented dev defaults (NOT for production).
JWT_SECRET=replace-with-32-plus-char-random-string-for-jwt-signing
ANON_KEY=replace-with-jwt-signed-by-JWT_SECRET-with-role-anon
SERVICE_ROLE_KEY=replace-with-jwt-signed-by-JWT_SECRET-with-role-service_role

# GoTrue site URL — used as the base for password-reset and OAuth callback links
SITE_URL=http://localhost:3000

# ----- Authentik OIDC federation into GoTrue ------------------------------
# Fill these in after bringing Authentik up and creating the OIDC application
# (the blueprint at deploy/authentik/blueprints/webapp-oidc-provider.yaml
# auto-creates it on first boot, then prints the client ID/secret in the
# Authentik server logs).
GOTRUE_EXTERNAL_KEYCLOAK_ENABLED=true
GOTRUE_EXTERNAL_KEYCLOAK_CLIENT_ID=authentik-client-id-placeholder
GOTRUE_EXTERNAL_KEYCLOAK_SECRET=authentik-client-secret-placeholder
GOTRUE_EXTERNAL_KEYCLOAK_REDIRECT_URI=http://localhost:8000/auth/v1/callback
GOTRUE_EXTERNAL_KEYCLOAK_URL=http://authentik-server:9000/application/o/webapp/

# ----- Authentik server ---------------------------------------------------
AUTHENTIK_SECRET_KEY=replace-with-50-plus-char-random-string
AUTHENTIK_POSTGRES_PASSWORD=authentik-pg-change-me
AUTHENTIK_BOOTSTRAP_EMAIL=admin@example.test
AUTHENTIK_BOOTSTRAP_PASSWORD=change-me-after-first-boot
AUTHENTIK_BOOTSTRAP_TOKEN=replace-with-random-token-for-initial-api-access

# ----- Frontend (app container) -------------------------------------------
# These are baked into the Vite build at image build time. For dev they
# point at Kong; for prod, the public URL of your Kong-fronted Supabase.
VITE_SUPABASE_URL=http://localhost:8000
VITE_SUPABASE_PUBLISHABLE_KEY=${ANON_KEY}
